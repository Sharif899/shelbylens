# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Aptos account address (hex, starting with 0x)
SHELBY_ACCOUNT_ADDRESS=0xYOUR_ACCOUNT_ADDRESS_HERE

# Network: TESTNET | MAINNET | SHELBYNET
SHELBY_NETWORK=TESTNET

# (Optional) Aptos Labs API key — avoids rate limits
# Get one at: https://docs.shelby.xyz/sdks/typescript/acquire-api-keys
SHELBY_API_KEY=aptoslabs_XXXX
